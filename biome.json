{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "plugin/**/*.ts",
      "plugin/**/*.json",
      ".claude-plugin/**/*.json",
      "*.ts",
      "*.json",
      "*.jsonc",
      "!!**/node_modules",
      "!!**/dist",
      "!!.claude"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  }
}
